# PRODUCTION ENVIRONMENT TEMPLATE
# Copy this to .env and fill in with REAL production values
# NEVER commit .env files with real secrets!

# ============ CRITICAL SECURITY (Change these!) ============
ENVIRONMENT=production
DEBUG=false

# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_32_CHARACTER_STRING

# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_TO_RANDOM_32_CHARACTER_STRING

# ============ API KEYS (from your accounts) ============
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME_YOUR_PRODUCTION_KEY

# Optional: Get from: https://github.com/settings/tokens
# Leave empty to use public API (rate limited to ~60 requests/hour)
GITHUB_TOKEN=ghp_CHANGE_ME_YOUR_PRODUCTION_TOKEN

# ============ CORS (your domains only) ============
# Format: comma-separated, no spaces
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============ DATABASE ============
# SQLite file location (should be mounted volume in Docker)
CHAT_DB_PATH=/var/lib/portfolio/chat_history.db

# Chroma vector database path
CHROMA_DB_PATH=/var/lib/portfolio/chroma_db

# ============ LOGGING ============
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============ PORTFOLIO INFORMATION ============
# Name to display
PORTFOLIO_NAME=Your Name

# Your GitHub profile URL
PORTFOLIO_GITHUB=https://github.com/yourusername

# Your LinkedIn profile URL
PORTFOLIO_LINKEDIN=https://linkedin.com/in/yourprofile

# IMPORTANT: Keep these empty in production (sensitive data)
PORTFOLIO_PHONE=
PORTFOLIO_EMAIL=contact@yourdomain.com
PORTFOLIO_LOCATION=

# ============ FRONTEND ============
# Your production domain
REACT_APP_API_URL=https://api.yourdomain.com

# ============ SERVER ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============ FEATURE FLAGS ============
FEATURE_CHAT_HISTORY=true
FEATURE_SHARE_CONVERSATIONS=true
FEATURE_CV_DOWNLOAD=true
FEATURE_CONTACT_FORM=false
FEATURE_ANALYTICS=false

# ============ RATE LIMITING ============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============ GITHUB INTEGRATION ============
GITHUB_ENABLED=true
GITHUB_USERNAME=yourusername
GITHUB_INCLUDE_README=true
GITHUB_INCLUDE_STARS=true
GITHUB_INCLUDE_LANGUAGES=true
GITHUB_INCLUDE_TOPICS=true
